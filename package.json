{
  "name": "my-switcher-chrome-extension",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "npm run build:chrome",
    "build:chrome": "node scripts/build-extension.mjs chrome",
    "build:firefox": "node scripts/build-extension.mjs firefox",
    "package:chrome": "npm run build:chrome && node scripts/package-extension.mjs chrome",
    "package:firefox": "npm run build:firefox && node scripts/package-extension.mjs firefox",
    "preview": "vite preview",
    "clean": "node --input-type=module -e \"import {rmSync} from 'node:fs'; ['dist','artifacts'].forEach((dir) => rmSync(dir, {recursive: true, force: true}));\"",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.4.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "canvas": "^3.2.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
