{
  "manifest_version": 3,
  "name": "My Switcher",
  "version": "1.0.0",
  "description": "Quickly switch between Google AI apps and Google services with multiple accounts in Firefox.",
  "action": {
    "default_title": "My Switcher",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png"
    }
  },
  "background": {
    "scripts": [
      "background.js"
    ],
    "type": "module"
  },
  "permissions": [
    "storage",
    "scripting"
  ],
  "optional_host_permissions": [
    "https://accounts.google.com/*"
  ],
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "96": "icon-96.png",
    "128": "icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "my-switcher@example.com"
    }
  }
}
