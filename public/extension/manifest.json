{
  "manifest_version": 3,
  "name": "My Switcher",
  "version": "1.0",
  "description": "Quickly switch between Google AI apps with multiple accounts.",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage",
    "tabs"
  ],
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}
